# ---------------------------------------------------------------------------
# Simple Chat Agent - environment configuration
#
# Copy this file to `.env` and fill in the values for the provider you're
# using. Only the block matching LLM_PROVIDER needs to be populated - the
# others can stay blank.
# ---------------------------------------------------------------------------

# --- General -----------------------------------------------------------
APP_NAME=Simple Chat Agent
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
CORS_ALLOW_ORIGINS=*

# --- Model selection -----------------------------------------------------
# One of: openai | anthropic | mistral | gemini | custom_openai | custom_anthropic
LLM_PROVIDER=openai
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
LLM_STREAMING=true
HISTORY_TURNS=10
SYSTEM_PROMPT="You are a helpful, concise assistant. Answer the user's question directly. If knowledge base context is provided below, ground your answer in it and say so when the context doesn't cover the question."

# --- OpenAI --------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic -------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# --- Mistral ---------------------------------------------------------------
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# --- Google Gemini -----------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=

# --- Custom OpenAI-compatible endpoint --------------------------------------
# Use this when an OpenAI-compatible model is served through an internal
# gateway (e.g. WSO2 AI Gateway) instead of api.openai.com directly.
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_BASE_URL=
CUSTOM_OPENAI_MODEL=
# Optional extra headers the gateway needs, as a JSON object:
# CUSTOM_OPENAI_EXTRA_HEADERS={"X-Gateway-Client":"simple-chat-agent"}
CUSTOM_OPENAI_EXTRA_HEADERS=

# --- Custom Anthropic-compatible endpoint -----------------------------------
# Same idea, for an Anthropic-compatible model proxied through a gateway.
CUSTOM_ANTHROPIC_API_KEY=
CUSTOM_ANTHROPIC_BASE_URL=
CUSTOM_ANTHROPIC_MODEL=
CUSTOM_ANTHROPIC_VERSION=2023-06-01
CUSTOM_ANTHROPIC_EXTRA_HEADERS=

# --- Embeddings (only used if the Pinecone knowledge base is enabled) -------
# One of: openai | custom_openai
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
# Leave blank to reuse OPENAI_API_KEY / CUSTOM_OPENAI_API_KEY / CUSTOM_OPENAI_BASE_URL.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# --- Pinecone knowledge base (optional - leave blank to disable RAG) -------
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_TOP_K=4
PINECONE_CREATE_IF_MISSING=true
